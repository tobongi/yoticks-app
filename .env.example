# Public values embedded in the Expo bundle
EXPO_PUBLIC_API_URL=https://api.yoticks.app
EXPO_PUBLIC_SUPPORT_EMAIL=support@yoticks.app
# Keep false until the provider-confirmation endpoint is live and verified.
EXPO_PUBLIC_ENABLE_PAID_CHECKOUT=false

# Server-only values. Never prefix secrets with EXPO_PUBLIC_.
JWT_SECRET=replace-with-at-least-32-random-bytes
CORS_ORIGINS=https://www.yoticks.app
CLIENT_URL=https://www.yoticks.app
PASSWORD_RESET_WEBHOOK_URL=https://automation.example.com/yoticks/password-reset
PASSWORD_RESET_DEEP_LINK_BASE=yoticks://auth/reset
MBIYOPAY_API_BASE_URL=https://dashboard.mbiyo.africa
MBIYOPAY_API_KEY=
MBIYOPAY_WEBHOOK_SECRET=
MBIYOPAY_WEBHOOK_URL=https://api.tobongi.com/api/payments/mobile-money/webhook
# Server-side kill switch. Set true only after the public webhook readiness probe succeeds.
PAID_CHECKOUT_ENABLED=false
DATABASE_URL=file:./prisma/production.db
PORT=4000
